# ===========================================
# Application Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# API Configuration
VITE_API_URL=http://localhost:8000

# Telemetry Configuration
VITE_TELEMETRY_HOST=

# Authentication
# Set to true to bypass JWT auth and dynamically fetch a token from POST /api/token (dev only)
VITE_BYPASS_AUTH=false
# (Fallback) Provide a static access token — used only if /api/token call fails
VITE_AUTH_TOKEN=

# Bypass Auth: Token Generation
# When VITE_BYPASS_AUTH=true, these values are sent to POST /api/token to fetch a real access token
VITE_BYPASS_AUTH_MOBILE=0000000000
VITE_BYPASS_AUTH_NAME=Dev User
VITE_BYPASS_AUTH_ROLE=developer
# VITE_BYPASS_AUTH_METADATA=  # optional, defaults to null

# ===========================================
# GitHub Secrets for GCP Artifact Registry
# ===========================================
# Add these as GitHub Secrets in:
# Repository → Settings → Secrets and variables → Actions → New repository secret

# GCP Project Configuration
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=asia-south1
# GCP_ARTIFACT_REPO=your-artifact-repo-name

# Service Account Key (paste the entire JSON content)
# GCP_SA_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
